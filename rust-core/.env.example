# Sufrix core configuration. Copy to `.env`; values are baked into the library
# at BUILD time by crates/sufrix-core/build.rs (via cargo:rustc-env), so hosts
# never carry base-url/endpoint knowledge — per the rebuild brief.
#
#   cp .env.example .env

# API base URL the generated client targets.
MADAR_BASE_URL=https://api.sufrix.app

# Environment name: prod | staging | dev
MADAR_ENV=prod
